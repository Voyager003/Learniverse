# App
PORT=3000
NODE_ENV=development
APP_CORS_ORIGINS=http://localhost:3001

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=your_password_here
